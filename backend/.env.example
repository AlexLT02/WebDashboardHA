# Lokale Entwicklung: Kopiere diese Datei nach backend/.env und fülle die Werte.
# backend/.env ist gitignored — Token landet nie im Repo.
#
# Im Add-on-Betrieb (HA OS) werden diese Werte NICHT gebraucht — dort kommt der
# Zugang automatisch über SUPERVISOR_TOKEN.

# URL deiner HA-Instanz (ohne abschließenden Slash).
HA_URL=http://homeassistant.local:8123

# Long-Lived Access Token: HA öffnen → unten links auf deinen Namen (Profil)
# → Tab "Sicherheit" → ganz unten "Langlebige Zugriffstoken" → Token erstellen.
HA_TOKEN=hier_dein_long_lived_token_einfuegen
